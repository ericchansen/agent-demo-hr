# Copy to .env for local dev. NEVER commit a real .env.
# All values below are safe local dev defaults — no secrets.

# Mock signed-in user for the dev identity shim (must exist in hr_access).
# Swap between the two personas to demo row-level security.
ROSTER_DEV_UPN=emea.hrbp@contoso.com

# Local SQLite path (auto-built by hr-demo or data/seed_local.py)
ROSTER_DB_PATH=data/hr_local.db

# Where export_roster writes files in dev
ROSTER_EXPORT_DIR=exports

